# ────────────────────────────────────────────────────────────
# .env.example  –  Copy to .env and fill in real values.
#                  NEVER commit the real .env to version control.
# ────────────────────────────────────────────────────────────

# AWS credentials (IAM user or role with bedrock:InvokeModel permission)
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY_HERE

# AWS region where Amazon Bedrock Nova models are available
# (Nova is available in us-east-1, us-west-2, and ap-northeast-1)
AWS_REGION=us-east-1
